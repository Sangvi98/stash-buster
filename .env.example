# ── OAuth 2.0 credentials (for user login) ──
# 1. Go to https://www.ravelry.com/pro/developer
# 2. Create an app with OAuth 2.0 access type
# 3. Set callback URL to: https://localhost:5001/callback

RAVELRY_CLIENT_ID=your_oauth_client_id
RAVELRY_CLIENT_SECRET=your_oauth_client_secret

# ── Basic Auth credentials (for API data reads) ──
# 1. Create a SECOND app at https://www.ravelry.com/pro/developer
# 2. Choose "Basic Auth: read only" access type
# 3. Copy the access key (username) and personal key (password)

RAVELRY_ACCESS_KEY=your_basic_auth_access_key
RAVELRY_PERSONAL_KEY=your_basic_auth_personal_key

FLASK_SECRET_KEY=change-this-to-a-random-string
